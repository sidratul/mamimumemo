# ===========================================
# Mami API - Environment Configuration
# ===========================================

# Server Configuration
PORT=8000
NODE_ENV=development

# MongoDB Configuration
# For local development (without Docker):
MONGO_URI=mongodb://localhost:27017/mami-db

# For Docker development:
# MONGO_URI=mongodb://mami-admin:mami-password-2026@mongo:27017/mami-db?authSource=admin

# For production (update with your credentials):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/mami-db?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Optional: MongoDB Atlas (Production)
# MONGO_ATLAS_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/mami-db?retryWrites=true&w=majority

# Optional: File Upload Configuration
# MAX_FILE_SIZE=5242880
# UPLOAD_DIR=./uploads

# Optional: CORS Configuration
# CORS_ORIGIN=http://localhost:3000

# Optional: Logging
# LOG_LEVEL=info
