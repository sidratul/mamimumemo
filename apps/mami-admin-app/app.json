{
  "expo": {
    "name": "mami-admin-app",
    "slug": "mami-admin-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-admin-icon.png",
    "scheme": "mamiadminapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mami.adminapp"
    },
    "android": {
      "package": "com.mami.adminapp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
          "foregroundImage": "./assets/images/logo-admin-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo-admin-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-admin.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://api.example.com",
      "graphqlUrl": "https://api.example.com/graphql"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
